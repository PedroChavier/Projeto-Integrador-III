rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isDefaultUserProfile() {
      return request.resource.data.uid == request.auth.uid &&
        request.resource.data.isAdmin == false &&
        request.resource.data.role == 'user';
    }

    function keepsProtectedUserFields() {
      // Bloqueia alterações em campos sensíveis sem exigir que eles existam no
      // documento. Usamos diff().affectedKeys() porque comparar campos ausentes
      // diretamente em request.resource.data falha quando o documento criado
      // pelo backend não inclui role/isAdmin (perfis legados ou criados via
      // Admin SDK na Cloud Function de registro).
      return !request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['uid', 'cpf', 'email', 'role', 'isAdmin', 'createdAt']);
    }

    match /startups/{startupId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /startups/{startupId}/{document=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    // New balcão system — wallet and positions per user
    match /usuarios/{userId}/wallet/{doc} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /usuarios/{userId}/positions/{startupId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /usuarios/{userId}/order_history/{orderId} {
      allow read: if isOwner(userId);
      allow write: if false;
    }

    match /orders/{orderId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /usuarios/{userId} {
      allow create: if isOwner(userId) && isDefaultUserProfile();
      allow read: if isOwner(userId);
      allow update: if isOwner(userId) && keepsProtectedUserFields();
      allow delete: if false;
    }

    match /usuarios/{userId}/transacoes/{transacaoId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update, delete: if false;
    }

    match /perguntas/{perguntaId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.idAutor == request.auth.uid;
      allow update, delete: if false;
    }

    match /2fa_settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
